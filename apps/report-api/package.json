{
  "name": "report-api",
  "version": "1.0.0",
  "description": "API for HTTP Archive reports",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "function": "DATABASE=tech-report-api-prod functions-framework --target=app",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:live": "bash ../../scripts/test-api.sh",
    "build": "docker build -t report-api -f apps/report-api/Dockerfile .",
    "lint": "eslint .",
    "docker": "docker run -p 8080:8080 report-api"
  },
  "dependencies": {
    "@google-cloud/bigquery": "8.3.1",
    "@google-cloud/firestore": "8.5.0",
    "@google-cloud/functions-framework": "5.0.2",
    "@google-cloud/storage": "7.19.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "pg": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@httparchive/eslint-config": "*",
    "@httparchive/jest-config": "*",
    "@jest/transform": "30.4.1",
    "eslint": "^9.0.0",
    "jest": "30.3.0",
    "supertest": "7.2.2"
  }
}

