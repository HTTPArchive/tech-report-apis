{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "cache": false
    },
    "test": {
      "outputs": ["coverage/**"],
      "inputs": ["**/*.js", "!coverage/**", "package.json", "jest.config.*"]
    },
    "lint": {
      "inputs": ["**/*.js", "eslint.config.*", "package.json"]
    },
    "test:live": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
