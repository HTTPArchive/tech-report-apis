{
  "name": "report-api",
  "version": "1.0.0",
  "description": "API for HTTP Archive reports",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "function": "DATABASE=tech-report-api-prod functions-framework --target=app",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:live": "bash ../scripts/test-api.sh",
    "build": "docker build -t report-api .",
    "docker": "docker run -p 8080:8080 report-api"
  },
  "dependencies": {
    "@google-cloud/bigquery": "8.3.0",
    "@google-cloud/firestore": "8.6.0",
    "@google-cloud/functions-framework": "5.0.2",
    "@google-cloud/storage": "7.19.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "pg": "8.20.0",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@jest/transform": "30.3.0",
    "jest": "30.3.0",
    "supertest": "7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.js",
      "!index.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "globals": {
      "__filename": false,
      "__dirname": false
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(.*\\.mjs$))"
    ],
    "transform": {}
  }
}
